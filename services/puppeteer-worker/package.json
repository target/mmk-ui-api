{
	"name": "puppeteer-worker",
	"version": "1.0.0",
	"description": "merrymaker puppeteer worker",
	"main": "dist/index.js",
	"scripts": {
		"test": "npm run build && node --test src/*.test.js",
		"test:watch": "npm run build:watch & node --test --watch src/*.test.js src/*-test.js",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"format": "biome format --write",
		"build": "tsc --emitDeclarationOnly && node scripts/esbuild.mjs",
		"build:watch": "node scripts/esbuild.mjs --watch",
		"start": "tsx src/index.ts",
		"start:dist": "node dist/index.js",
		"start:env": "node --env-file=.env dist/index.js",
		"worker": "tsx src/worker-main.ts",
		"worker:dist": "node dist/worker-main.js",
		"worker:env": "node --env-file=.env dist/worker-main.js",
		"dev": "tsx --watch src/index.ts",
		"examples": "tsx examples/examples.ts",
		"demo": "tsx src/index.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"esbuild": "^0.28.1",
		"tsx": "^4.22.5",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"uuid": "^11.1.1"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1079.0",
		"@aws-sdk/s3-request-presigner": "^3.1079.0",
		"@azure/storage-blob": "^12.33.0",
		"@google-cloud/storage": "^7.21.0",
		"ioredis": "^5.11.1",
		"minio": "^8.0.7",
		"puppeteer": "^25.3.0",
		"undici": "^8.6.0",
		"yaml": "^2.9.0"
	}
}
